# SCANNER is paper-trading by default. Never commit a real secret.
PORT=3000
SCAN_INTERVAL_SECONDS=30
MIN_SCORE=79
MIN_LIQUIDITY_USD=30000
MAX_FDV_LIQUIDITY_RATIO=25
MAX_POSITION_USD=25
MAX_DAILY_LOSS_USD=50
TAKE_PROFIT_PERCENT=35
STOP_LOSS_PERCENT=12
TRAILING_STOP_PERCENT=10
MAX_HOLD_MINUTES=60
# Paper brokerage: all costs below are simulated, logged, and configurable.
PAPER_STARTING_CASH_USD=1000
PAPER_DEX_FEE_BPS=30
PAPER_SLIPPAGE_BPS=100
PAPER_SOL_USD=150
PAPER_BASE_FEE_LAMPORTS=5000
PAPER_PRIORITY_FEE_LAMPORTS=100000
PAPER_JITO_TIP_LAMPORTS=0
# Daily report: America/Denver observes Mountain daylight time automatically.
DAILY_REPORT_TIME_ZONE=America/Denver
DAILY_REPORT_HOUR=20
# Railway injects this from Postgres; leave blank for local memory-only development.
DATABASE_URL=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Recommended for executable route validation. Do not commit a key.
JUPITER_API_KEY=
MAX_OPEN_POSITIONS=3
MAX_TOP_HOLDER_PERCENT=25
MAX_QUOTE_PRICE_IMPACT_PERCENT=15
# Require this bearer token for POST endpoints in production.
CONTROL_API_KEY=
# Automatic paper entries only—never signs or submits a real transaction.
AUTO_PAPER_TRADE=true
# Optional: set a Telegram bot token and chat ID for alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Deliberately protected. Live execution is not implemented until an audited signer/executor is supplied.
EXECUTION_MODE=paper
